<?xml version="1.0" encoding="utf-8" ?>
<sf:WindowEx x:Class="Starward.Features.ViewHost.NoPermissionWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lang="using:Starward.Language"
             xmlns:local="using:Starward.Features.ViewHost"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sf="using:Starward.Frameworks"
             Title="Starward"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">

    <sf:WindowEx.SystemBackdrop>
        <MicaBackdrop />
    </sf:WindowEx.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>


        <TextBlock Grid.ColumnSpan="2"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Text="Starward" />



        <StackPanel Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="12,24,12,24"
                    VerticalAlignment="Center"
                    Spacing="8">
            <TextBlock FontSize="16"
                       Text="{x:Bind lang:Lang.NoPermissionWindow_NoPermissionToFolderRestartOrClose}"
                       TextWrapping="Wrap" />
            <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap">
                <Hyperlink Click="Hyperlink_Click" UnderlineStyle="None">
                    <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Folder}" />
                </Hyperlink>
            </TextBlock>
        </StackPanel>




        <Button Grid.Row="2"
                Grid.Column="0"
                Margin="12,8,6,8"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind RestartAsAdminCommand}"
                Content="{x:Bind lang:Lang.NoPermissionWindow_RestartAsAdministrator}"
                Style="{ThemeResource AccentButtonStyle}" />

        <Button Grid.Row="2"
                Grid.Column="1"
                Margin="8,6,12,8"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind CloseCommand}"
                Content="{x:Bind lang:Lang.DownloadGamePage_Close}" />



    </Grid>

</sf:WindowEx>
